<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!-- parallel="tests" is the correct mode for Cucumber/TestNG parallel execution.
     parallel="methods" would attempt to parallelise TestNG methods, not Cucumber scenarios. -->
<suite name="BDD Parallel Suite" parallel="tests" thread-count="4">
    <test name="BDD Tests Parallel">
        <classes>
            <class name="com.nidhinsai.runners.ParallelRunner"/>
        </classes>
    </test>
</suite>